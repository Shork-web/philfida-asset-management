# Firebase configuration
# Get these from Firebase Console > Project Settings > Your apps
# https://console.firebase.google.com/

VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123

# Optional: Master key(s) for sign-up and region access.
# Single key (legacy): users who sign up see all assets/subscriptions.
#   VITE_SIGNUP_MASTER_KEY=your-secret-master-key
# Multiple keys per region (Regions 1–13): sign-up key determines which region's data the user can see.
#   VITE_MASTER_KEYS={"1":"PhilFIDA1","2":"PhilFIDA2","3":"PhilFIDA3","4":"PhilFIDA4","5":"PhilFIDA5","6":"PhilFIDA6","7":"PhilFIDA7","8":"PhilFIDA8","9":"PhilFIDA9","10":"PhilFIDA10","11":"PhilFIDA11","12":"PhilFIDA12","13":"PhilFIDA13"}
