# Firebase configuration
# Get these from Firebase Console > Project Settings > Your apps
# https://console.firebase.google.com/

VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123

# Canonical public URL of this app (no trailing slash). Used in asset QR codes as https://YOUR_DOMAIN/a/{assetId}
# so printed codes open the right site. In dev, omit to use the current origin (e.g. http://localhost:5173).
# VITE_PUBLIC_APP_URL=https://your-app.vercel.app

# Admin master keys per region — sign-up key determines which region's data the user can manage.
VITE_MASTER_KEYS={"1":"PhilFIDA1","2":"PhilFIDA2",...,"13":"PhilFIDA13"}

# Super Admin — grants access to all regions. Reusable.
VITE_SUPER_ADMIN_MASTER_KEY=PhilFIDA-SuperAdmin

# Viewer keys per region — sign-up key determines which region the viewer can browse (read-only).
VITE_VIEWER_KEYS={"1":"ViewFIDA1","2":"ViewFIDA2",...,"13":"ViewFIDA13"}

# Legacy single master key (deprecated, use VITE_MASTER_KEYS instead)
# VITE_SIGNUP_MASTER_KEY=your-secret-master-key
