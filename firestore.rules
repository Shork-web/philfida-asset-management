rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function getUserRegion() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('region', 'all')
        : 'all';
    }

    function getUserRole() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'admin')
        : 'admin';
    }

    function isViewer() {
      return getUserRole() == 'viewer';
    }

    match /config/signup {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    match /users/{userId} {
      // Users can read/write their own profile
      allow read, write: if request.auth != null && request.auth.uid == userId;
      // Super admin (region = 'all') can read, update, or delete any user profile
      allow read, write, delete: if request.auth != null && getUserRegion() == 'all';
    }

    match /assets/{assetId} {
      allow read: if request.auth != null &&
        (getUserRegion() == 'all' || resource.data.region == getUserRegion());
      allow create: if request.auth != null && !isViewer() &&
        (getUserRegion() == 'all' || request.resource.data.region == getUserRegion());
      allow update, delete: if request.auth != null && !isViewer() &&
        (getUserRegion() == 'all' || resource.data.region == getUserRegion());
    }

    match /subscriptions/{subscriptionId} {
      allow read: if request.auth != null &&
        (getUserRegion() == 'all' || resource.data.region == getUserRegion());
      allow create: if request.auth != null && !isViewer() &&
        (getUserRegion() == 'all' || request.resource.data.region == getUserRegion());
      allow update, delete: if request.auth != null && !isViewer() &&
        (getUserRegion() == 'all' || resource.data.region == getUserRegion());
    }

    // QR scan log: each user sees only their own entries (all signed-in devices share the same list).
    match /scanHistory/{entryId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
      allow update: if false;
    }

  }
}
