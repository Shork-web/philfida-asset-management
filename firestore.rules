rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /assets/{assetId} {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      let userRegion = userDoc.data == null ? 'all' : userDoc.data.get('region', 'all');
      allow read: if request.auth != null && (userRegion == 'all' || (resource.data.region != null && resource.data.region == userRegion));
      allow create: if request.auth != null && (userRegion == 'all' || request.resource.data.region == userRegion);
      allow update, delete: if request.auth != null && (userRegion == 'all' || (resource.data.region != null && resource.data.region == userRegion));
    }

    match /subscriptions/{subscriptionId} {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      let userRegion = userDoc.data == null ? 'all' : userDoc.data.get('region', 'all');
      allow read: if request.auth != null && (userRegion == 'all' || (resource.data.region != null && resource.data.region == userRegion));
      allow create: if request.auth != null && (userRegion == 'all' || request.resource.data.region == userRegion);
      allow update, delete: if request.auth != null && (userRegion == 'all' || (resource.data.region != null && resource.data.region == userRegion));
    }
  }
}
